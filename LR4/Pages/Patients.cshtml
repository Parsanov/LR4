@page
@model LR4.Pages.PatientsModel
@{
    ViewData["Title"] = "Пацієнти стоматологічної клініки";
    var css = Model.Settings.ToCssStyle();
}

<section class="text-center mt-4">
    <h1 class="display-5">🦷 Пацієнти стоматологічної клініки</h1>
    <p class="text-muted">Перегляд записів, керування стилем таблиці (патерн Memento)</p>
</section>

<hr class="my-3" />


<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white fw-semibold">
        ⚙️ Налаштування відображення таблиці
    </div>
    <div class="card-body">

        
        <form method="post" asp-page-handler="Set" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()

            
            <div class="col-md-3">
                <label class="form-label fw-semibold">Шрифт</label>
                <select name="FontFamily" class="form-select">
                    @foreach (var f in new[]{"Arial","Times New Roman","Courier New","Georgia","Verdana","Tahoma","Trebuchet MS"})
                    {
                        if (Model.Settings.FontFamily == f)
                        {
                            <option value="@f" selected>@f</option>
                        }
                        else
                        {
                            <option value="@f">@f</option>
                        }
                    }
                </select>
            </div>

            
            <div class="col-md-2">
                <label class="form-label fw-semibold">Розмір (px)</label>
                <input type="number" name="FontSize" min="10" max="24"
                       value="@Model.Settings.FontSize" class="form-control" />
            </div>

            
            <div class="col-md-2">
                <label class="form-label fw-semibold">Колір тексту</label>
                <div class="input-group">
                    <input type="color" name="FontColor"
                           value="@Model.Settings.FontColor"
                           class="form-control form-control-color" style="max-width:50px" />
                    <span class="input-group-text font-monospace small" id="colorLabel">@Model.Settings.FontColor</span>
                </div>
            </div>

            
            <div class="col-md-1 text-center">
                <label class="form-label fw-semibold d-block">Bold</label>
                <input type="checkbox" name="IsBold" value="true"
                       class="form-check-input fs-4"
                       @(Model.Settings.IsBold ? "checked" : "") />
                <input type="hidden" name="IsBold" value="false" />
            </div>

            
            <div class="col-md-1 text-center">
                <label class="form-label fw-semibold d-block">Italic</label>
                <input type="checkbox" name="IsItalic" value="true"
                       class="form-check-input fs-4"
                       @(Model.Settings.IsItalic ? "checked" : "") />
                <input type="hidden" name="IsItalic" value="false" />
            </div>

            
            <div class="col-md-3 d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">
                    ✅ Set
                </button>
            </div>
        </form>

        <hr class="my-3" />

        
        <div class="d-flex gap-2 flex-wrap">

            <form method="post" asp-page-handler="Undo">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary @(!Model.CanUndo ? "disabled" : "")">
                    ↩ Undo
                </button>
            </form>

            <form method="post" asp-page-handler="Redo">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary @(!Model.CanRedo ? "disabled" : "")">
                    ↪ Redo
                </button>
            </form>

            <form method="post" asp-page-handler="Reset">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    🔄 Reset
                </button>
            </form>

            <a asp-page-handler="ExportExcel" class="btn btn-success ms-auto">
                ⬇ Завантажити Excel
            </a>
        </div>

        
        <div class="mt-3 p-2 bg-light rounded border small text-muted">
            <strong>Поточні налаштування:</strong>
            Шрифт: <strong>@Model.Settings.FontFamily</strong>,
            Розмір: <strong>@Model.Settings.FontSize px</strong>,
            Колір: <strong style="color:@Model.Settings.FontColor">■ @Model.Settings.FontColor</strong>,
            Bold: <strong>@(Model.Settings.IsBold ? "✓" : "✗")</strong>,
            Italic: <strong>@(Model.Settings.IsItalic ? "✓" : "✗")</strong>
            &nbsp;|&nbsp;
            Undo: <strong>@(Model.CanUndo ? "доступно" : "недоступно")</strong>
            &nbsp;|&nbsp;
            Redo: <strong>@(Model.CanRedo ? "доступно" : "недоступно")</strong>
        </div>
    </div>
</div>


<section class="container mt-2">
    <h2 class="mb-3">Список пацієнтів</h2>

    @if (!Model.Patients.Any())
    {
        <div class="alert alert-info">Записів не знайдено. Запустіть seed для заповнення даними.</div>
    }
    else
    {
        <div class="table-responsive">
            <table id="patients-table" class="table table-striped table-hover table-bordered align-middle"
                   style="@css">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Прізвище</th>
                        <th>Ім'я</th>
                        <th>По-батькові</th>
                        <th>Дата народження</th>
                        <th>Стать</th>
                        <th>Стан пацієнта</th>
                        <th>Код лікаря</th>
                        <th>Послуга</th>
                        <th>Дата та час візиту</th>
                        <th>Вартість (грн)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Patients)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>@p.Surname</td>
                            <td>@p.Name</td>
                            <td>@p.Pname</td>
                            <td>@p.Dr.ToString("dd.MM.yyyy")</td>
                            <td>@(p.Gender ? "Чоловіча" : "Жіноча")</td>
                            <td class="text-truncate" style="max-width:150px" title="@p.StateComments">
                                @(p.StateComments ?? "—")
                            </td>
                            <td>@p.DoctorCode</td>
                            <td class="text-truncate" style="max-width:150px" title="@p.Posluga">
                                @p.Posluga
                            </td>
                            <td>@p.TimeVisit.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">@p.Cost.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
<script>
    document.querySelector('input[type=color]').addEventListener('input', function () {
        document.getElementById('colorLabel').textContent = this.value;
    });
</script>
}

<style>
    #patients-table tbody td {
        font-family: @Model.Settings.FontFamily !important;
        font-size: @(Model.Settings.FontSize)px !important;
        color: @Model.Settings.FontColor !important;
        font-weight: @(Model.Settings.IsBold ? "bold" : "normal") !important;
        font-style: @(Model.Settings.IsItalic ? "italic" : "normal") !important;
    }
</style>
