@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center mt-5">
    <h1 class="display-4">Експорт книг</h1>
    <p class="text-muted">Оберіть формат для завантаження</p>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-page-handler="DownloadJson" class="btn btn-primary btn-lg">
            ⬇ JSON
        </a>
        <a asp-page-handler="DownloadTXT" class="btn btn-success btn-lg">
            ⬇ TXT
        </a>
        <a asp-page-handler="DownloadXML" class="btn btn-warning btn-lg">
            ⬇ XML
        </a>
    </div>
</div>

<hr class="my-5" />

<div class="text-center mt-4">
    <h2 class="display-6">Імпорт книг</h2>
    <p class="text-muted">Завантажте файл формату JSON, TXT або XML</p>

    <form method="post" asp-page-handler="ImportReport" enctype="multipart/form-data"
          class="d-flex justify-content-center gap-3 mt-4 align-items-center">
        <input type="file" name="file" accept=".json,.txt,.xml" class="form-control w-auto" />
        <button type="submit" class="btn btn-secondary btn-lg">
            ⬆ Завантажити
        </button>
    </form>

    <hr class="my-5" />

    <div class="container mt-4">
    <h2 class="mb-3">📚 Список книг</h2>
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Назва</th>
                <th>Автор</th>
                <th>Дата виходу</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.Books)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Title</td>
                      <td>@{
                            @if (book.Author is null)
                                { <span class="text-muted">Невідомо</span>}
                                    @book.Author
                    }</td>
                    <td>@book.DateRelease?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>